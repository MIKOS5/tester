<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>My Mini Hub</title>
<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: black;
    color: white;
    overflow: hidden;
}

/* Top nav */
#nav {
    position: fixed;
    top: 0;
    width: 100%;
    background: #111;
    padding: 10px;
    text-align: center;
    z-index: 100;
}

button {
    margin: 5px;
    padding: 10px 20px;
    cursor: pointer;
    background: #222;
    color: white;
    border: none;
    border-radius: 5px;
}

button:hover {
    background: #555;
}

/* Sections */
.section {
    position: absolute;
    top: 50px;
    left: 0;
    width: 100%;
    height: calc(100% - 50px);
    display: none;
    justify-content: center;
    align-items: center;
    font-size: 30px;
    transition: opacity 0.4s;
}

.active {
    display: flex;
    opacity: 1;
}
</style>
</head>
<body>

<div id="nav">
    <button onclick="showSection('home')">Home</button>
    <button onclick="showSection('visual')">Visual</button>
    <button onclick="showSection('about')">About</button>
</div>

<!-- Sections -->
<div id="home" class="section active">
    <div>🚀 Welcome to the Mini Hub!</div>
</div>

<div id="visual" class="section">
    <canvas id="canvas"></canvas>
</div>

<div id="about" class="section">
    <div>This is the About section of your hub.</div>
</div>

<script>
// Section navigation
function showSection(id){
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
}

// Example visual effect in the Visual section
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');

function resizeCanvas(){
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight - 50;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

let t = 0;
function animate() {
    ctx.fillStyle = "black";
    ctx.fillRect(0,0,canvas.width,canvas.height);

    for(let i=0;i<50;i++){
        let x = canvas.width/2 + Math.sin(t + i) * 200;
        let y = canvas.height/2 + Math.cos(t + i) * 200;
        ctx.fillStyle = `hsl(${(i*20+t*10)%360},100%,60%)`;
        ctx.fillRect(x,y,5,5);
    }
    t += 0.02;
    requestAnimationFrame(animate);
}
animate();
</script>

</body>
</html>
