<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gear & Tools Hub</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background: #f4f4f4;
    }
    header {
      background: #333;
      color: white;
      text-align: center;
      padding: 30px 10px;
    }
    header h1 {
      margin: 0;
      font-size: 2em;
    }
    .container {
      max-width: 900px;
      margin: 40px auto;
      padding: 20px;
      background: white;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      border-radius: 8px;
    }
    h2 {
      text-align: center;
      color: #333;
    }
    .links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
      margin-top: 30px;
    }
    .link-card {
      flex: 1 1 200px;
      max-width: 250px;
      background: #333;
      color: white;
      text-align: center;
      padding: 20px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
      transition: transform 0.2s, background 0.2s;
    }
    .link-card:hover {
      background: #555;
      transform: translateY(-5px);
    }
  </style>
</head>
<body>

<header>
  <h1>My Gear & Tools Hub</h1>
  <p>Quick access to your inventory and music battle tools</p>
</header>

<div class="container">
  <h2>Available Tools & Pages</h2>
  <div class="links">
    <a class="link-card" href="inventory.html" target="_blank">Gear Inventory</a>
    <a class="link-card" href="Front.html" target="_blank">For Sale</a>
    <a class="link-card" href="inventorydetails.html" target="_blank">Inventory Details</a>
    <!-- Add more links as needed -->
  </div>
</div>

</body>
</html>
